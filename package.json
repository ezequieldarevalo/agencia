{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "seed": "npx tsx prisma/seed.ts",
    "cap:sync": "npx cap sync",
    "mobile:dev:android": "CAPACITOR_SERVER_URL=http://10.0.2.2:3000 npx cap sync android && npx cap open android",
    "mobile:dev:ios": "npx cap sync ios && npx cap open ios",
    "mobile:build:android": "CAPACITOR_SERVER_URL=$CAPACITOR_SERVER_URL npx cap sync android && npx cap open android",
    "mobile:build:ios": "CAPACITOR_SERVER_URL=$CAPACITOR_SERVER_URL npx cap sync ios && npx cap open ios"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
